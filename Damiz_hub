end)

-- Obter ID do servidor atual
local function getCurrentServerId()
    return game.JobId
end

-- Gerar ID
local function generateServerId()
    local currentId = getCurrentServerId()
    if currentId and currentId ~= "" then
        return currentId
    else
        return "⚠️ ERRO: Não foi possível obter o ID"
    end
end

-- Botão GERAR ID
generateBtn.MouseButton1Click:Connect(function()
    local newID = generateServerId()
    idDisplayText.Text = newID
    idDisplayText.TextColor3 = Color3.new(0, 0.8, 1)
    
    pcall(function()
        setclipboard(newID)
    end)
    
    statusLabel.Text = "✅ ID copiado para a área de transferência!"
    statusLabel.TextColor3 = Color3.new(0, 0.8, 1)
    task.wait(2)
    statusLabel.Text = ""
end)

-- Teleportar para servidor
local function teleportToServer(targetId)
    if targetId and targetId ~= "" and targetId ~= "⚠️ ERRO: Não foi possível obter o ID" then
        if game.JobId == targetId then
            statusLabel.Text = "⚠️ Você já está neste servidor!"
            statusLabel.TextColor3 = Color3.new(1, 0.8, 0)
            task.wait(2)
            statusLabel.Text = ""
            return
        end
        
        local success, err = pcall(function()
            TeleportService:TeleportToInstance(targetId, player)
        end)
        
        if success then
            statusLabel.Text = "🔄 Teleportando para o servidor..."
            statusLabel.TextColor3 = Color3.new(0, 0.8, 1)
        else
            statusLabel.Text = "❌ Erro ao teleportar: " .. tostring(err)
            statusLabel.TextColor3 = Color3.new(1, 0.2, 0.2)
            task.wait(2)
            statusLabel.Text = ""
        end
    else
        statusLabel.Text = "❌ ID inválido! Cole um ID válido."
        statusLabel.TextColor3 = Color3.new(1, 0.2, 0.2)
        task.wait(2)
        statusLabel.Text = ""
    end
end

-- Botão CARREGA ID
loadBtn.MouseButton1Click:Connect(function()
    local id = idInput.Text
    if id and id ~= "" then
        teleportToServer(id)
        idInput.Text = ""
    else
        statusLabel.Text = "❌ Por favor, cole um ID de servidor válido!"
        statusLabel.TextColor3 = Color3.new(1, 0.2, 0.2)
        task.wait(2)
        statusLabel.Text = ""
    end
end)

