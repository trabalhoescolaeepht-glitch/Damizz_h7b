-- Trocar abas
local function switchTab(tabNum)
    if tabNum == 1 then
        tab1.BackgroundColor3 = Color3.new(0.05, 0.1, 0.2)
        tab1.BorderColor3 = Color3.new(0, 0.6, 1)
        tab1.TextColor3 = Color3.new(0, 0.8, 1)
        tab2.BackgroundColor3 = Color3.new(0.02, 0.05, 0.1)
        tab2.BorderColor3 = Color3.new(0.1, 0.3, 0.5)
        tab2.TextColor3 = Color3.new(0.3, 0.5, 0.7)
        content1.Visible = true
        content2.Visible = false
    else
        tab2.BackgroundColor3 = Color3.new(0.05, 0.1, 0.2)
        tab2.BorderColor3 = Color3.new(0, 0.6, 1)
        tab2.TextColor3 = Color3.new(0, 0.8, 1)
        tab1.BackgroundColor3 = Color3.new(0.02, 0.05, 0.1)
        tab1.BorderColor3 = Color3.new(0.1, 0.3, 0.5)
        tab1.TextColor3 = Color3.new(0.3, 0.5, 0.7)
        content1.Visible = false
        content2.Visible = true
    end
end

tab1.MouseButton1Click:Connect(function()
